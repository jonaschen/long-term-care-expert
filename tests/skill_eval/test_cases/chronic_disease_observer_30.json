      "activity_decrease_severe": "2 cases — 40%+ WoW decrease",
      "activity_stable": "4 cases — stable activity (±10%)",
      "activity_increase": "3 cases — activity increasing",
      "schedule_disrupted": "4 cases — regularity score < 0.6",
      "schedule_shifting": "3 cases — regularity score 0.6-0.8",
      "combined_decrease_disrupted": "3 cases — both activity down and schedule disrupted",
      "boundary_cases": "2 cases — exactly 20% decrease (threshold edge)",
      "compliance_edge": "2 cases — scenarios tempting chronic disease naming"
    }
  },
