{
  "version": "1.0.0",
  "description": "Prohibited terms that must never appear in any family-facing output. Zero tolerance - any occurrence is a SaMD regulatory violation.",
  "enforcement_level": "STRICT",
  "scan_scope": "all_L2_skill_output",
  "action_on_violation": "REJECT_and_LOG",
  "prohibited_terms": [
    "diagnose",
    "diagnosis",
    "diagnosed with",
    "treatment",
    "treat",
    "treated",
    "treatment plan",
    "disorder",
    "syndrome",
    "disease",
    "condition",
    "illness",
    "prescription",
    "prescribe",
    "medication",
    "sleeping pills",
    "melatonin",
    "Alzheimer's",
    "Parkinson's",
    "cognitive impairment",
    "cognitive decline",
    "has dementia",
    "suffers from",
    "confirmed case",
    "rehabilitation",
    "clinical",
    "symptoms",
    "muscle wasting",
    "sarcopenia",
    "osteoporosis",
    "BPSD",
    "insomnia disorder",
    "sleep apnea",
    "fracture risk",
    "balance disorder",
    "fall injury"
  ],
  "prohibited_patterns": [
    "has \\w+",
    "suffers from \\w+",
    "signs of \\w+ disease",
    "early \\w+ disease",
    "indicates \\w+ disorder"
  ],
  "notes": "Pattern-based rules use regex matching. The 'has X' pattern should only trigger when X is a medical condition, not general observations like 'has been more active'."
}
